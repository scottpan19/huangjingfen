<view><view class="p-20"><view class="relative"><image class="w-full h-400 rd-24rpx block" mode="aspectFill" src="{{cardInfo.cover_image}}"></image><view class="gift-badge px-14 rd-40rpx flex-center z-10"><text hidden="{{!(cardInfo.type==1)}}" class="iconfont icon-ic_card3 fs-32 text-yellow"></text><text hidden="{{!(cardInfo.type==2)}}" class="iconfont icon-ic_gift2 fs-32 text-red"></text><text hidden="{{!(cardInfo.type==1)}}" class="fs-24 pl-8">{{cardInfo.balance+"元礼品卡"}}</text><text hidden="{{!(cardInfo.type==2)}}" class="fs-24 pl-8">兑换卡</text></view></view><block wx:if="{{cardInfo.type==2}}"><view class="w-full bg--w111-fff rd-16rpx px-24 mt-20"><view class="flex-between-center pt-32"><view class="fs-28">可兑换商品 <block wx:if="{{cardInfo.exchange_type==1}}"><text class="fs-24 text--w111-999 pl-12">该兑换卡可兑换以下商品</text></block><block wx:else><text class="fs-24 text--w111-999 pl-12">任选 <text class="Regular text-red">{{cardInfo.gift_num}}</text> 件兑换</text></block></view><block wx:if="{{cardInfo.exchange_type==2}}"><text class="fs-28"><text class="text-red">{{totalLimitNum}}</text>{{'/'+cardInfo.gift_num+''}}</text></block></view><view class="pb-32 product-box"><block wx:for="{{cardInfo.product}}" wx:for-item="item" wx:for-index="index" wx:key="index"><view class="mt-24 flex"><image class="block w-200 h-200 rd-16rpx" src="{{item.image}}"></image><view class="flex-1 h-200 flex-col justify-between pl-20"><view><view class="w-444 line2 fs-28 h-80 lh-40rpx">{{item.store_name}}</view><view class="inline-block max-w-444 h-38 lh-38rpx mt-8 bg--w111-f5f5f5 text--w111-999 rd-20rpx px-12 fs-22 line1">{{''+item.suk+''}}</view></view><view class="flex-between-center"><base-money vue-id="{{'37af86e0-1-'+index}}" money="{{item.price}}" symbolSize="24" integerSize="36" decimalSize="24" color="#e93323" weight="{{true}}" bind:__l="__l"></base-money><block wx:if="{{cardInfo.exchange_type==1}}"><text class="Regular fs-28">{{"x"+item.limit_num}}</text></block><block wx:else><view class="flex-y-center"><button class="w-44 h-44 flex-center" disabled="{{item.limit_num<=0}}" data-event-opts="{{[['tap',[['decreaseLimitNum',[index]]]]]}}" bindtap="__e"><text class="iconfont icon-ic_Reduce fs-24"></text></button><view class="w-88 h-44 text-center lh-44rpx bg--w111-f5f5f5">{{item.limit_num}}</view><button class="w-44 h-44 flex-center" disabled="{{totalLimitNum>=cardInfo.gift_num}}" data-event-opts="{{[['tap',[['increaseLimitNum',[index]]]]]}}" bindtap="__e"><text class="iconfont icon-ic_increase fs-24"></text></button></view></block></view></view></view></block></view></view></block><view class="w-full bg--w111-fff rd-16rpx p-24 mt-20 fs-28 lh-42rpx"><block wx:if="{{cardInfo.type==1}}"><view class="pb-20">储值金额<text class="fs-26 text--w111-666 pl-16">{{"¥"+cardInfo.balance}}</text></view></block><view>有效期至：<text class="fs-26 text--w111-666 pl-16">{{cardInfo.valid_type==1?'永久有效':cardInfo.fixed_time[1]}}</text></view></view><view class="w-full bg--w111-fff rd-16rpx px-24 mt-20"><view class="fs-28 pt-32">使用须知</view><view class="pt-12 fs-26 text--w111-666 lh-36rpx space-line pb-32">{{cardInfo.instructions}}</view></view><view class="w-full bg--w111-fff rd-16rpx px-24 mt-20"><view class="fs-28 pt-32">礼品卡详情</view><view class="pt-12 fs-26 text--w111-666 lh-36rpx space-line pb-32"><rich-text nodes="{{cardInfo.description}}"></rich-text></view></view><view class="h-200"></view></view><view class="fixed-lb w-full pb-safe bg--w111-fff z-99"><view class="w-full h-108 flex-between-center px-20"><button class="btn-box w-full h-72 rd-40rpx flex-center fs-26 text--w111-fff" disabled="{{disabled}}" data-event-opts="{{[['tap',[['exchangeGift',['$event']]]]]}}" bindtap="__e">确认兑换</button></view></view><uni-popup class="vue-ref" vue-id="37af86e0-2" data-ref="popup" bind:__l="__l" vue-slots="{{['default']}}"><view><view class="gift_pop bg--w111-fff relative"><image class="header-pic" src="{{imgHost+'/statics/images/activity/gift_open_pic.png'}}"></image><view class="success-text"><view class="text-center text-red fs-34 fw-500 lh-48rpx">成功到账</view><view class="text-center fs-26 lh-36rpx pt-24">{{cardInfo.balance+"元已储值到您的账户中"}}</view><view class="flex-x-center mt-54"><view data-event-opts="{{[['tap',[['toMoney',['$event']]]]]}}" class="btn-box w-280 h-80 rd-40rpx flex-center fs-28 text--w111-fff" bindtap="__e">去看看</view></view></view></view><view class="flex-center mt-94"><text data-event-opts="{{[['tap',[['closeGift',['$event']]]]]}}" class="iconfont icon-ic_close1 text--w111-fff fs-50" bindtap="__e"></text></view></view></uni-popup></view>