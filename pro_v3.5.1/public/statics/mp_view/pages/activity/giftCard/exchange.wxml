<view class="container"><view class="bg-card" style="{{'background-image:'+(headerBg)+';'}}"></view><view class="bg--w111-fff rd-24rpx form-card"><view class="w-full bg--w111-f9f9f9 rd-12rpx pl-24 mt-38"><input class="w-full h-88 fs-30 lh-42rpx" type="text" placeholder="请输入卡号" placeholder-class="fs-30 text--w111-b3b3b3" data-event-opts="{{[['input',[['__set_model',['$0','card_number','$event',[]],['cardForm']]]]]}}" value="{{cardForm.card_number}}" bindinput="__e"/></view><view class="w-full bg--w111-f9f9f9 rd-12rpx pl-24 mt-32"><input class="w-full h-88 fs-30 lh-42rpx" type="text" placeholder="请输入密码" placeholder-class="fs-30 text--w111-b3b3b3" data-event-opts="{{[['input',[['__set_model',['$0','card_pwd','$event',[]],['cardForm']]]]]}}" value="{{cardForm.card_pwd}}" bindinput="__e"/></view><button class="w-full h-88 rd-44rpx flex-center text--w111-fff bg-btn fs-28 mt-54" disabled="{{disabled}}" data-event-opts="{{[['tap',[['exchangeConfirm',['$event']]]]]}}" bindtap="__e">立即验证</button></view></view>