<block wx:if="{{showBox}}"><view data-event-opts="{{[['touchmove',[['',['$event']]]]]}}" class="previewImg data-v-3d719c3b" catchtouchmove="__e"><view data-event-opts="{{[['tap',[['close',['$event']]]]]}}" class="mask data-v-3d719c3b" bindtap="__e"><swiper class="mask-swiper data-v-3d719c3b" current="{{currentIndex}}" circular="{{circular}}" duration="{{duration}}" data-event-opts="{{[['change',[['changeSwiper',['$event']]]]]}}" bindchange="__e"><block wx:for="{{list}}" wx:for-item="src" wx:for-index="i" wx:key="i"><swiper-item class="flex flex-column justify-center align-center data-v-3d719c3b"><image class="mask-swiper-img data-v-3d719c3b" src="{{src.image}}" mode="widthFix"></image><view class="mask_sku data-v-3d719c3b"><text class="sku_name data-v-3d719c3b">{{src.suk}}</text><text class="sku_price fs-36 fw-600 data-v-3d719c3b"><block wx:if="{{src.integral}}"><text class="data-v-3d719c3b">{{src.integral+" 积分 +"}}</text></block><text class="money-fix data-v-3d719c3b"></text>{{(price||src.price)+" 元"}}</text></view></swiper-item></block></swiper></view><block wx:if="{{$root.g0>0}}"><view class="pagebox data-v-3d719c3b">{{$root.m0+1+" / "+$root.g1}}</view></block></view></block>